# ─── App ────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# ─── Database ────────────────────────────────────────────────────────
# SQLite (default for local dev — no setup needed)
DATABASE_URL="file:./dev.db"

# PostgreSQL / Supabase (uncomment for production)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/photomind"

# ─── Supabase (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Google OAuth (for app login + Drive) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Drive scopes: https://www.googleapis.com/auth/drive.readonly
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ─── AI Adapter ────────────────────────────────────────────────────
# Options: mock | deepface | openai
AI_ADAPTER=mock

# OpenAI (only needed if AI_ADAPTER=openai)
OPENAI_API_KEY=

# ─── Backend API ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
API_SECRET=shared-secret-between-next-and-fastapi

# ─── Storage ────────────────────────────────────────────────────────
# Options: local | supabase | s3
STORAGE_ADAPTER=local
LOCAL_UPLOAD_DIR=./uploads

# S3 compatible (uncomment for s3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=photomind
